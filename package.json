{
  "name": "hotspotr",
  "version": "2.0.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "description": "Business planning tool using heatmaps to identify optimal business locations via demographic, wage, and competitor density data.",
  "main": "server.js",
  "scripts": {
    "server": "node server.js",
    "client": "cd client && npm start",
    "start": "pm2-runtime start ecosystem.config.js --env production",
    "dev": "concurrently \"nodemon server.js\" \"npm run client\"",
    "build": "cd client && npm install && npm run build",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "installDeps": "npm install && cd client && npm install",
    "lint": "eslint . --ext .js"
  },
  "author": "Will Blake",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "connect-ensure-login": "^0.1.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-request-id": "^1.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.3.2",
    "express-winston": "^4.2.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.12.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pm2": "^5.4.3",
    "redis": "^5.0.0",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "winston": "^3.17.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willblake01/hotspotr.git"
  },
  "keywords": [
    "heatmap",
    "business-planning",
    "location-analysis",
    "demographics"
  ],
  "bugs": {
    "url": "https://github.com/willblake01/hotspotr/issues"
  },
  "homepage": "https://github.com/willblake01/hotspotr#readme"
}
