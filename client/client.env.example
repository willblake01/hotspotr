# client/.env.example
# Copy this file to client/.env and fill in your values.
# Never commit client/.env
# All variables must be prefixed with REACT_APP_ to be accessible in the browser.

# ── Mapbox ────────────────────────────────────────────────
# Get a free public token (pk.*) at https://mapbox.com
# Never use a secret token (sk.*) here — it will be exposed in the browser bundle
REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── API ───────────────────────────────────────────────────
# In development the proxy in package.json handles routing,
# but useful for explicit axios base URL configuration
REACT_APP_API_URL=http://localhost:3001

# ── Census Bureau ─────────────────────────────────────────
# Free API key at https://api.census.gov/data/key_signup.html
REACT_APP_CENSUS_API_KEY=your_census_api_key_here

# ── Bureau of Labor Statistics ────────────────────────────
# Free API key at https://www.bls.gov/developers/home.htm
REACT_APP_BLS_API_KEY=your_bls_api_key_here

# ── Environment ───────────────────────────────────────────
REACT_APP_ENV=development
